# --- STAGE 1: Build ---
FROM eclipse-temurin:26-jdk-jammy AS build
WORKDIR /app

# 1. Copy the Maven wrapper files from the backend folder into the container's root
COPY backend/.mvn/ .mvn
COPY backend/mvnw backend/pom.xml ./

# 2. Copy your backend source code into a 'src' folder at the container's root
COPY backend/src ./src

# 3. Clean build command (No monorepo flags needed anymore!)
RUN ./mvnw clean package -DskipTests

# --- STAGE 2: Run ---
FROM eclipse-temurin:26-jre-jammy
WORKDIR /app

# Copy the built JAR from Stage 1 (it will be in the /app/target folder)
COPY --from=build /app/target/*.jar app.jar

# Expose your API and Socket.IO ports
EXPOSE 5174
EXPOSE 5175

ENTRYPOINT ["java", "-jar", "app.jar"]