{
  "name": "obs-canvas",
  "version": "1.0.0",
  "private": true,
  "description": "Canvas overlay for Open Broadcaster Software (OBS)",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "installConfig": {
    "hoisting": "none"
  },
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && mvnw spring-boot:run",
    "dev": "concurrently -n \"VITE,SPRING\" -c \"blue,green\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install-all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.x.x"
  }
}
